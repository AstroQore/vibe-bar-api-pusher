# Required: remote API endpoint (PUT method; the API also accepts POST as equivalent)
VIBEBAR_API_URL=https://your-dashboard.example.com/api/quotas

# Required: Bearer token your dashboard issued
VIBEBAR_API_TOKEN=replace-with-your-bearer-token

# Optional: HTTP method, defaults to PUT. The API also accepts POST.
# VIBEBAR_API_METHOD=PUT

# Optional: source directory, defaults to ~/.vibebar/quotas
# VIBEBAR_QUOTAS_DIR=/Users/YOUR_USERNAME/.vibebar/quotas

# Optional: vibe-bar settings.json (used to enumerate miscProviderInstances
# for multi-account support). Defaults to a sibling of VIBEBAR_QUOTAS_DIR.
# VIBEBAR_SETTINGS_PATH=/Users/YOUR_USERNAME/.vibebar/settings.json

# Optional: HTTP timeout in seconds, defaults to 10
# VIBEBAR_TIMEOUT_SECONDS=10

# Optional: log level (DEBUG / INFO / WARNING / ERROR), defaults to INFO
# VIBEBAR_LOG_LEVEL=INFO
